---
layout: null
---
[
  {% for post in site.posts %}
    {
      "title": {{ post.archive_title | default: post.title | jsonify }},
      "post_title": {{ post.title | jsonify }},
      "section": {{ post.section | default: "OI" | jsonify }},
      "section_slug": {{ post.section_slug | default: "oi" | jsonify }},
      "url": {{ post.url | relative_url | jsonify }},
      "date": {{ post.date | date: "%Y-%m-%d" | jsonify }},
      "tags": {{ post.tags | jsonify }},
      "summary": {{ post.summary | default: post.excerpt | strip_html | strip_newlines | normalize_whitespace | jsonify }},
      "excerpt": {{ post.content | strip_html | strip_newlines | normalize_whitespace | truncate: 800 | jsonify }}
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
